---
import BaseLayout from '../../layouts/BaseLayout.astro';

const episodes = [
  'Prompting as design, not magic',
  'How old dogs debug AI output',
  'Refactor rituals with copilots'
];
---

<BaseLayout title="Videos | newtricks.ai" description="Video breakdowns of AI-native coding workflows.">
  <section class="mx-auto w-full max-w-5xl px-6 py-16">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">Videos</p>
    <h1 class="mt-3 font-display text-6xl uppercase leading-none text-zinc-100">Watch + learn</h1>
    <div class="mt-10 space-y-6">
      {episodes.map((episode, idx) => (
        <article class="card flex items-start justify-between gap-4">
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-signal">Episode 0{idx + 1}</p>
            <h2 class="mt-2 font-display text-4xl uppercase leading-[0.95] text-zinc-100">{episode}</h2>
          </div>
          <span class="rounded border border-phosphor/60 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.16em] text-phosphor">Soon</span>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
