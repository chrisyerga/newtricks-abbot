---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout title="Blog | newtricks.ai" description="AI workflow posts for experienced programmers.">
  <section class="mx-auto w-full max-w-4xl px-6 py-16">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">Blog</p>
    <h1 class="mt-3 font-display text-6xl uppercase leading-none text-zinc-100">New tricks journal</h1>
    <p class="mt-6 max-w-2xl text-zinc-300">Notes, experiments, and field-tested workflows from building with AI as an experienced dev.</p>

    <div class="mt-10 space-y-6">
      {posts.map((post) => (
        <article class="card transition hover:border-signal/60">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-muted">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
          <h2 class="mt-3 font-display text-4xl uppercase leading-[0.95] text-zinc-100">{post.data.title}</h2>
          <p class="mt-3 text-zinc-300">{post.data.description}</p>
          <a class="mt-4 inline-block font-mono text-xs uppercase tracking-[0.18em] text-phosphor hover:text-signal" href={`/blog/${post.slug}`}>
            Read post →
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
